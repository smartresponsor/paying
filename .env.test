APP_ENV=test
APP_DEBUG=0
APP_SECRET=payment_test_secret

# Default local test topology (SQLite + SQLite).
DATABASE_URL="sqlite:///%kernel.project_dir%/var/payment.test.data.sqlite"
INFRA_URL="sqlite:///%kernel.project_dir%/var/payment.test.infra.sqlite"

# For PostgreSQL user data (local instance or Docker pg service), override only DATABASE_URL.
# Example (host machine): DATABASE_URL="pgsql://app:app@127.0.0.1:5432/payment_test"
# Example (inside docker-compose app service): DATABASE_URL="pgsql://app:app@pg:5432/payment_test"

STRIPE_WEBHOOK_SECRET=payment_test_whsec

PAYMENT_TEST_QUARANTINE_LEGACY=0
