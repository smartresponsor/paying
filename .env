APP_ENV=dev
APP_DEBUG=1
APP_SECRET=devsecret

# PostgreSQL for user data
DATABASE_URL="pgsql://app:app@127.0.0.1:5432/payment"

# SQLite for application / infrastructure data
INFRA_URL="sqlite:///%kernel.project_dir%/var/payment.app.sqlite"

STRIPE_WEBHOOK_SECRET=
ADYEN_HMAC_SECRET=
PAYMENT_WEBHOOK_ALLOW_UNKNOWN=1

# Redis for idempotency (optional)
REDIS_URL=redis://127.0.0.1:6379/0
IDEM_TTL=86400

# OIDC verification
OIDC_ISS=
OIDC_AUD=
OIDC_JWKS_URL=
OIDC_DISABLED=0
