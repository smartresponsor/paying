
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=devsecret

# Postgres (Data)
DATABASE_URL=postgresql://user:pass@127.0.0.1:5432/app?serverVersion=15&charset=utf8

# MySQL (Infra projection)
INFRA_URL=mysql://user:pass@127.0.0.1:3306/infra?serverVersion=8.0&charset=utf8mb4

STRIPE_WEBHOOK_SECRET=
ADYEN_HMAC_SECRET=
PAYMENT_WEBHOOK_ALLOW_UNKNOWN=1

# Redis for idempotency (optional)
REDIS_URL=redis://127.0.0.1:6379/0
IDEM_TTL=86400

# OIDC verification
OIDC_ISS=
OIDC_AUD=
OIDC_JWKS_URL=
OIDC_DISABLED=0
