{# Marketing America Corp. Oleksandr Tishchenko #}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Payment Console</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<div class="container py-4">
    <div class="mb-4">
        <h1 class="h3 mb-1">Payment Console</h1>
        <p class="text-muted mb-0">Minimal internal Bootstrap/Twig smoke page for create, start, finalize, read, and refund flows.</p>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'danger' ? 'danger' : 'success' }}" role="alert">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="row g-4 mb-4">
        <div class="col-12 col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5">Create payment</h2>
                    <p class="text-muted small">Creates a new payment aggregate through the app-owned service.</p>
                    {{ form_start(create_form) }}
                        {{ form_row(create_form.orderId) }}
                        {{ form_row(create_form.amountMinor) }}
                        {{ form_row(create_form.currency) }}
                        <button class="btn btn-primary" type="submit">Create</button>
                    {{ form_end(create_form) }}
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5">Start payment</h2>
                    <p class="text-muted small">Creates a payment and immediately starts provider execution.</p>
                    {{ form_start(start_form) }}
                        {{ form_row(start_form.amount) }}
                        {{ form_row(start_form.currency) }}
                        {{ form_row(start_form.provider) }}
                        <button class="btn btn-primary" type="submit">Start</button>
                    {{ form_end(start_form) }}
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5">Finalize payment</h2>
                    <p class="text-muted small">Finalize an existing payment by entering its ULID and provider result details.</p>
                    {{ form_start(finalize_form) }}
                        {{ form_row(finalize_form.paymentId) }}
                        {{ form_row(finalize_form.provider) }}
                        {{ form_row(finalize_form.providerRef) }}
                        {{ form_row(finalize_form.gatewayTransactionId) }}
                        {{ form_row(finalize_form.status) }}
                        <button class="btn btn-primary" type="submit">Finalize</button>
                    {{ form_end(finalize_form) }}
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 align-items-start">
        <div class="col-12 col-xl-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="h5 mb-0">Recent payments</h2>
                        <span class="badge text-bg-secondary">{{ recent_payments|length }} shown</span>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th scope="col">Payment ID</th>
                                    <th scope="col">Status</th>
                                    <th scope="col">Amount</th>
                                    <th scope="col">Currency</th>
                                    <th scope="col">Provider ref</th>
                                </tr>
                            </thead>
                            <tbody>
                            {% for payment in recent_payments %}
                                <tr>
                                    <td><code>{{ payment.id }}</code></td>
                                    <td><span class="badge text-bg-light border">{{ payment.status.value }}</span></td>
                                    <td>{{ payment.amount }}</td>
                                    <td>{{ payment.currency }}</td>
                                    <td>{{ payment.providerRef ?: '—' }}</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="5" class="text-muted">No payments available yet. Load fixtures or create one through the console.</td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-xl-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h2 class="h5">Refund payment</h2>
                    <p class="text-muted small">Refund an existing payment directly from the internal console smoke layer.</p>
                    {{ form_start(refund_form) }}
                        {{ form_row(refund_form.paymentId) }}
                        {{ form_row(refund_form.amount) }}
                        {{ form_row(refund_form.provider) }}
                        <button class="btn btn-outline-primary" type="submit">Refund</button>
                    {{ form_end(refund_form) }}
                </div>
            </div>
        </div>
    </div>
</div>
</body>
</html>
