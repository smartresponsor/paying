{# Marketing America Corp. Oleksandr Tishchenko #}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Payment Console</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<div class="container py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-end gap-2 mb-4">
        <div>
            <h1 class="h3 mb-1">Payment Console</h1>
            <p class="text-muted mb-0">Canonical operator UI for payment lifecycle, webhook visibility, and demo flow
                checks.</p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-sm btn-outline-secondary" href="/api/docs" target="_blank" rel="noopener">Open API
                docs</a>
            <a class="btn btn-sm btn-outline-secondary" href="/status" target="_blank" rel="noopener">Status</a>
            <a class="btn btn-sm btn-outline-secondary" href="/metrics" target="_blank" rel="noopener">Metrics</a>
        </div>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'danger' ? 'danger' : 'success' }} d-flex align-items-center"
                 role="alert">
                <strong class="me-2">{{ label == 'danger' ? 'Error:' : 'Success:' }}</strong>
                <span>{{ message }}</span>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" action="{{ path('payment_console') }}" class="row g-2 align-items-end">
                <div class="col-12 col-lg-5">
                    <label class="form-label mb-1" for="q">Search</label>
                    <input id="q" name="q" type="text" class="form-control" value="{{ filters.q }}"
                           placeholder="Payment ID / order ID / provider ref / currency / amount">
                </div>
                <div class="col-12 col-lg-3">
                    <label class="form-label mb-1" for="status">Status</label>
                    <select id="status" name="status" class="form-select">
                        {% set statuses = ['all', 'new', 'processing', 'completed', 'failed', 'refunded', 'canceled'] %}
                        {% for option in statuses %}
                            <option
                                value="{{ option }}" {{ filters.status == option ? 'selected' : '' }}>{{ option|title }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-12 col-lg-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Apply filters</button>
                    <a href="{{ path('payment_console') }}" class="btn btn-outline-secondary">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-12 col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5">Create payment</h2>
                    <p class="text-muted small">Create aggregate (`POST /api/payments`) using operator-friendly
                        form.</p>
                    {{ form_start(create_form) }}
                    {{ form_row(create_form.orderId) }}
                    {{ form_row(create_form.amountMinor) }}
                    {{ form_row(create_form.currency) }}
                    <button class="btn btn-primary" type="submit">Create payment</button>
                    {{ form_end(create_form) }}
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5">Start payment</h2>
                    <p class="text-muted small">Run start flow (`POST /payment/start`) through currently supported
                        providers.</p>
                    {{ form_start(start_form) }}
                    {{ form_row(start_form.orderId) }}
                    {{ form_row(start_form.amount) }}
                    {{ form_row(start_form.currency) }}
                    {{ form_row(start_form.provider) }}
                    <button class="btn btn-primary" type="submit">Start payment</button>
                    {{ form_end(start_form) }}
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 align-items-start">
        <div class="col-12 col-xl-8">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="h5 mb-0">Payments</h2>
                        <span class="badge text-bg-secondary">{{ payments|length }} shown</span>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                            <tr>
                                <th scope="col">Payment ID</th>
                                <th scope="col">Order ID</th>
                                <th scope="col">Status</th>
                                <th scope="col">Amount</th>
                                <th scope="col">Provider ref</th>
                                <th scope="col" class="text-end">Actions</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for payment in payments %}
                                <tr>
                                    <td><code>{{ payment.id }}</code></td>
                                    <td><code>{{ payment.orderId }}</code></td>
                                    <td><span class="badge text-bg-light border">{{ payment.status }}</span></td>
                                    <td>{{ payment.amount }} {{ payment.currency }}</td>
                                    <td>{{ payment.providerRef ?: '—' }}</td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-primary"
                                           href="{{ path('payment_console', {payment: payment.id, q: filters.q, status: filters.status}) }}">Open
                                            card</a>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="6" class="text-muted">No payments match the active filter. Adjust
                                        filters or create/start a payment.
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <h2 class="h5">Webhook / event visibility</h2>
                    <p class="text-muted small mb-3">Recent
                        events{{ selected_payment ? ' for payment ' ~ selected_payment.id : '' }}.</p>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                            <tr>
                                <th scope="col">Provider</th>
                                <th scope="col">External event</th>
                                <th scope="col">State</th>
                                <th scope="col">Received at</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for event in webhook_events %}
                                <tr>
                                    <td>{{ event.provider }}</td>
                                    <td><code>{{ event.externalEventId }}</code></td>
                                    <td><span class="badge text-bg-light border">{{ event.status }}</span></td>
                                    <td>{{ event.receivedAt }}</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="4" class="text-muted">No webhook events available yet.</td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-4">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h2 class="h5">Payment card</h2>
                    {% if selected_payment %}
                        <dl class="row mb-0 small">
                            <dt class="col-5 text-muted">Payment ID</dt>
                            <dd class="col-7"><code>{{ selected_payment.id }}</code></dd>
                            <dt class="col-5 text-muted">Order ID</dt>
                            <dd class="col-7"><code>{{ selected_payment.orderId }}</code></dd>
                            <dt class="col-5 text-muted">Status</dt>
                            <dd class="col-7"><span
                                    class="badge text-bg-light border">{{ selected_payment.status }}</span></dd>
                            <dt class="col-5 text-muted">Amount</dt>
                            <dd class="col-7">{{ selected_payment.amount }} {{ selected_payment.currency }}</dd>
                            <dt class="col-5 text-muted">Provider ref</dt>
                            <dd class="col-7">{{ selected_payment.providerRef ?: '—' }}</dd>
                            <dt class="col-5 text-muted">Updated at</dt>
                            <dd class="col-7">{{ selected_payment.updatedAt }}</dd>
                        </dl>
                    {% else %}
                        <p class="text-muted mb-0">Select a payment from the list to view details and prefill
                            actions.</p>
                    {% endif %}
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h2 class="h5">Finalize payment</h2>
                    <p class="text-muted small">Matches `POST /payment/finalize/{id}` behavior.</p>
                    {{ form_start(finalize_form) }}
                    {{ form_row(finalize_form.paymentId) }}
                    {{ form_row(finalize_form.provider) }}
                    {{ form_row(finalize_form.providerRef) }}
                    {{ form_row(finalize_form.providerTransactionId) }}
                    {{ form_row(finalize_form.status) }}
                    <button class="btn btn-primary" type="submit">Finalize payment</button>
                    {{ form_end(finalize_form) }}
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h2 class="h5">Refund payment</h2>
                    <p class="text-muted small">Matches `POST /api/payments/{id}/refund` behavior.</p>
                    {{ form_start(refund_form) }}
                    {{ form_row(refund_form.paymentId) }}
                    {{ form_row(refund_form.amount) }}
                    {{ form_row(refund_form.provider) }}
                    <button class="btn btn-outline-primary" type="submit">Refund payment</button>
                    {{ form_end(refund_form) }}
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <h2 class="h6">Natural demo path</h2>
                    <ol class="small mb-0">
                        <li>Create or start payment from this console.</li>
                        <li>Send webhook to `/webhook/stripe` or `/webhook/paypal`.</li>
                        <li>Run <code>php bin/console payment:outbox:process</code>.</li>
                        <li>Check updated status here and in API docs.</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>
</div>
</body>
</html>
