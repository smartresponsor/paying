{
  "info": {
    "name": "Payment API",
    "_postman_id": "00000000-0000-0000-0000-000000000001",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Start",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Idempotency-Key",
            "value": "e2e-1"
          }
        ],
        "url": {
          "raw": "http://localhost:8000/payment/start",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8000",
          "path": [
            "payment",
            "start"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\"amount\":\"1.23\",\"currency\":\"USD\",\"provider\":\"internal\"}"
        }
      }
    },
    {
      "name": "Finalize",
      "request": {
        "method": "POST",
        "url": {
          "raw": "http://localhost:8000/payment/finalize/{{id}}?provider=internal",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8000",
          "path": [
            "payment",
            "finalize",
            ":id"
          ],
          "query": [
            {
              "key": "provider",
              "value": "internal"
            }
          ]
        }
      }
    },
    {
      "name": "Webhook Stripe",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Stripe-Signature",
            "value": "{{sig}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "http://localhost:8000/payment/webhook/stripe",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8000",
          "path": [
            "payment",
            "webhook",
            "stripe"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\"type\":\"payment_intent.succeeded\",\"data\":{\"object\":{\"id\":\"pi_123\",\"metadata\":{\"payment\":\"<ULID>\"}}}}"
        }
      }
    }
  ]
}